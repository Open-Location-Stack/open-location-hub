APP_PORT=8080
POSTGRES_PORT=5432
POSTGRES_DB=openrtls
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
VALKEY_PORT=6379
MQTT_PORT=1883
MQTT_WS_PORT=9001

HTTP_LISTEN_ADDR=:8080
LOG_LEVEL=info
POSTGRES_URL=postgres://postgres:postgres@localhost:5432/openrtls?sslmode=disable
VALKEY_URL=redis://localhost:6379/0
MQTT_BROKER_URL=tcp://localhost:1883

AUTH_ENABLED=true
AUTH_MODE=none
AUTH_ISSUER=
AUTH_AUDIENCE=open-rtls-hub
AUTH_ALLOWED_ALGS=RS256
AUTH_STATIC_PUBLIC_KEYS=
AUTH_CLOCK_SKEW=30s
AUTH_OIDC_REFRESH_TTL=10m
AUTH_HTTP_TIMEOUT=5s
AUTH_PERMISSIONS_FILE=config/auth/permissions.yaml
AUTH_ROLES_CLAIM=groups
AUTH_OWNED_RESOURCES_CLAIM=owned_resources
